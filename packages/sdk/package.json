{
  "name": "@editoria/sdk",
  "version": "0.1.0",
  "description": "SDK leggero per collegare siti custom al CMS editoriale Editoria",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./seo": {
      "import": "./dist/helpers/seo.mjs",
      "require": "./dist/helpers/seo.js",
      "types": "./dist/helpers/seo.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/helpers/seo.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/helpers/seo.ts --format esm,cjs --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["cms", "headless", "editorial", "sdk"],
  "license": "MIT"
}
